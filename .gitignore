node_modules/
dist/
*.local
.DS_Store
*.log

# Local editor / preview tooling (keep contents out of git, but track published
# skills under .claude/skills/<name>/; their eval workspaces stay ignored).
.claude/*
!.claude/skills/
.claude/skills/*
!.claude/skills/urx-routing-planner/

# Tauri build artifacts
src-tauri/target/
src-tauri/gen/

# Generated third-party license bundle (regenerate with `cargo about generate`)
src-tauri/THIRD_PARTY_LICENSES.html

# Playwright E2E artifacts
test-results/
playwright-report/

# Intermediate icon source (regenerate with scripts/gen-icon.mjs) and unused
# mobile icon sets (this project targets desktop only)
scripts/app-icon.png
src-tauri/icons/android/
src-tauri/icons/ios/

# Local routing plans saved during development
/plans/

# Reference materials (copyrighted Yamaha PDFs, reverse-engineered protocol
# dumps, and their READMEs) live in a separate private repository. Excluded
# from this public repo entirely.
/reference/
