{
  "name": "urx-router",
  "version": "0.9.4",
  "description": "Routing planner for YAMAHA URX22 / URX44 / URX44V USB audio interfaces",
  "license": "MIT",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.7.1",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "build:demo": "tsc --noEmit && vite build --mode demo",
    "test": "vitest run",
    "test:e2e": "playwright test",
    "preview": "vite preview --port 4173 --strictPort",
    "reset:storage": "node scripts/reset-storage.mjs",
    "tauri": "tauri",
    "clean": "rm -rf node_modules/.vite dist && cargo clean --manifest-path src-tauri/Cargo.toml"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.0",
    "@tauri-apps/cli": "^2.11.3",
    "@types/node": "22",
    "esbuild": "^0.28.1",
    "typescript": "^6.0.3",
    "vite": "^8.0.16",
    "vitest": "^4.1.9"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild"
    ]
  }
}
