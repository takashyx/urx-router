{
  "name": "urx-router",
  "version": "1.1.2",
  "description": "Routing planner for YAMAHA URX22 / URX44 / URX44V USB audio interfaces",
  "license": "MIT",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.7.1",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "build:demo": "tsc --noEmit && vite build --mode demo",
    "test": "vitest run",
    "test:e2e": "playwright test",
    "format": "prettier --write \"src/**/*.ts\" \"e2e/**/*.ts\" \"scripts/**/*.mjs\" \"*.ts\"",
    "preview": "vite preview --port 4173 --strictPort",
    "reset:storage": "node scripts/reset-storage.mjs",
    "tauri": "tauri",
    "clean": "rm -rf node_modules/.vite dist && cargo clean --manifest-path src-tauri/Cargo.toml"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@tauri-apps/cli": "^2.11.4",
    "@types/node": "24",
    "esbuild": "^0.28.1",
    "jsdom": "^29.1.1",
    "prettier": "^3.9.5",
    "typescript": "^7.0.2",
    "vite": "^8.1.5",
    "vitest": "^4.1.10"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild"
    ]
  },
  "prettier": {
    "printWidth": 120
  }
}
